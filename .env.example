# VeriCTI-RAG configuration
# Copy to .env and modify as needed.
# The default values run the entire system offline with no API keys.

VERICTI_LLM_PROVIDER=mock
VERICTI_DATA_DIR=./data
VERICTI_DB_PATH=./data/vericti.db
VERICTI_CHROMA_DIR=./data/chroma

# Optional: enable LLM-augmented extraction
# VERICTI_LLM_PROVIDER=openai
# VERICTI_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
